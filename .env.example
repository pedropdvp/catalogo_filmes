# Exemplo de configuracao da ligacao ao MySQL.
# Copia este ficheiro para .env e ajusta os valores se necessario:
#   cp .env.example .env
# Se a tua password do MySQL nao estiver vazia, preenche DATABASE_PASSWORD.

PORT=3000
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=catalogo_filmes
